# Admin dashboard login (change in production)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Superadmin — bulk Excel import at /superadmin
SUPERADMIN_USERNAME=superadmin
SUPERADMIN_PASSWORD=superadmin123

# MongoDB
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority
MONGODB_DB_NAME=transhub

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
CLOUDINARY_FOLDER=traders_website

# Resend (email) — add when ready
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
ENQUIRY_TO_EMAIL=info@saasab2e.com

# Public site URL (used in newsletter links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
